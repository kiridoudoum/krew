{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" },
    { "src": "!(index.js|package.json|package-lock.json|vercel.json|*.md|node_modules/**)", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "index.js" },
    { "src": "/api/(.*)", "dest": "index.js" },
    { "src": "/chat", "dest": "index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
